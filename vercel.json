{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    { "src": "/__debug/(.*)", "dest": "/server.js" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/uploads/(.*)", "dest": "/server.js" },
    { "src": "/(.*\\.(css|js|json|png|jpg|jpeg|gif|svg|ico|webp|mp4|weba|webm|xml|txt))?$", "dest": "/server.js" },
    { "src": "/(.*\\.html?)?$", "dest": "/server.js" }
  ],
  "env": {
    "NODE_ENV": "production",
    "REPO_OWNER": "HollyHubDigital",
    "REPO_NAME": "hollyhub-visitors",
    "REPO_BRANCH": "main"
  }
}
