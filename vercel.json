{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/server.js" },
    { "src": "/__debug/(.*)", "dest": "/server.js" },
    { "src": "/(hollyhub.jpg|hollyhubhero.jpg|google.png|github.png|whatsapp.png)", "dest": "/server.js" },
    { "src": "/api/(.*)", "dest": "/server.js" }
  ],
  "rewrites": [
    { "source": "/hollyhub.jpg", "destination": "/assets/hollyhub.jpg" },
    { "source": "/hollyhubhero.jpg", "destination": "/assets/hollyhubhero.jpg" },
    { "source": "/google.png", "destination": "/assets/google.png" },
    { "source": "/github.png", "destination": "/assets/github.png" },
    { "source": "/whatsapp.png", "destination": "/assets/whatsapp.png" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(jpg|jpeg|png|gif|svg|ico|webp|css|js|json|woff|woff2|ttf|eot))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
