{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*\\.(css|js|json|png|jpg|jpeg|gif|svg|ico|webp|weba|webm))?$", "dest": "/server.js" },
    { "src": "/(.*\\.html?)?$", "dest": "/server.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
